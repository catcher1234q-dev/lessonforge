# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=LessonForge
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
# Keep the placeholder DATABASE_URL until you have a real Postgres instance.
# `LESSONFORGE_PERSISTENCE_MODE=auto` is the safe local default while Prisma cutover is unfinished.
# Switch to `prisma` only when you want strict database-only behavior with no JSON fallback.
# Runtime Prisma client URL:
# - Supabase on Vercel should use the pooled Supavisor URL here
# - add `?pgbouncer=true` when using the pooler host
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/lessonforge
# Direct database URL for Prisma CLI commands like migrate deploy
DIRECT_URL=postgresql://USER:PASSWORD@localhost:5432/lessonforge
LESSONFORGE_PERSISTENCE_MODE=auto

# Auth
AUTH_SECRET=replace_me_with_a_long_random_secret
NEXTAUTH_URL=http://localhost:3000
LESSONFORGE_ACCESS_COOKIE_SECRET=replace_me_with_a_long_random_secret
OWNER_EMAIL=owner@example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SITE_URL=https://lessonforgehub.com
SUPABASE_REDIRECT_URLS=https://lessonforgehub.com,https://lessonforgehub.com/auth/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_PRICE_TAX_BEHAVIOR=exclusive
STRIPE_PRICE_SELLER_BASIC_MONTHLY=price_replace_me
STRIPE_PRICE_SELLER_PRO_MONTHLY=price_replace_me

# Stripe Connect
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_replace_me_connect
STRIPE_CONNECTED_ACCOUNT_AVERY=acct_123
STRIPE_CONNECTED_ACCOUNT_MONICA=acct_123
STRIPE_CONNECTED_ACCOUNT_THEO=acct_123
STRIPE_CONNECTED_ACCOUNT_PRIYA=acct_123

# AI Provider
OPENAI_API_KEY=replace_me
GEMINI_API_KEY=replace_me
GOOGLE_API_KEY=

# File Storage
STORAGE_REGION=us-east-1
STORAGE_BUCKET=lessonforge-local
STORAGE_ACCESS_KEY=replace_me
STORAGE_SECRET_KEY=replace_me
STORAGE_ENDPOINT=

# Email
EMAIL_FROM=no-reply@lessonforgehub.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_replace_me

# Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=false
ANALYTICS_WRITE_KEY=

# Logging / Monitoring
LOG_LEVEL=info
SENTRY_DSN=

# Feature Flags
FEATURE_AI_ENABLED=true
FEATURE_DEMO_MODE=false
FEATURE_STRIPE_ENABLED=true
FEATURE_REVIEWS_ENABLED=true
FEATURE_REFUNDS_ENABLED=true
FEATURE_ADMIN_ENABLED=true
DEV_GRANT_PURCHASE_ENABLED=false

# AI Guardrails
AI_KILL_SWITCH=false
AI_DEFAULT_TIMEOUT_MS=30000
AI_MAX_INPUT_CHARACTERS=12000
AI_MAX_FILE_SIZE_BYTES=10000000

# Plan Limits
PLAN_STARTER_CREDITS=5
PLAN_BASIC_MONTHLY_CREDITS=100
PLAN_PRO_MONTHLY_CREDITS=300

# Search / Ranking
SEARCH_FRESHNESS_WINDOW_DAYS=14

# Demo
DEMO_SESSION_HOURS=24
